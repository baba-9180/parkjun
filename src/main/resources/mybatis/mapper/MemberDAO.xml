<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper 
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.parkjun.dao.MemberDAO">

  <!-- 전체 목록 -->
  <select id="listDao" resultType="com.parkjun.dto.MemberDTO">
    select * from member order by m_no asc
  </select>

  <!-- 회원번호 상세 -->
  <select id="viewDao" resultType="com.parkjun.dto.MemberDTO">
    select * from member where m_no = #{m_no}
  </select>

  <!-- 아이디 조회 -->
  <select id="findByMid" resultType="com.parkjun.dto.MemberDTO">
    select * from member where m_id = #{m_id}
  </select>

  <!-- 회원가입 -->
  <insert id="writeDao">
	  insert into member (
	    m_no,
	    m_id,
	    m_pw,
	    m_name,
	    m_sex,
	    m_email,
	    m_tel,
	    m_role
	  ) values (
	    MEMBER_SEQ.nextval,
	    #{m_id},
	    #{m_pw},
	    #{m_name},
	    #{m_sex},
	    #{m_email},
	    #{m_tel},
	    'USER'
	  )
	</insert>

  <!-- 정보 수정 -->
  <update id="updateDao">
    update member
    set
      m_id   = #{m_id},
      m_pw   = #{m_pw},
      m_name = #{m_name},
      m_email= #{m_email},
      m_tel  = #{m_tel}
    where m_no = #{m_no}
  </update>

  <!-- 삭제 -->
  <delete id="deleteDao">
    delete from member where m_no = #{param1}
  </delete>

</mapper>